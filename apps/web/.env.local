# API Configuration
# En desarrollo, el proxy de Next.js redirige /api/* al backend
# En producción, usa la URL completa de tu backend
NEXT_PUBLIC_API_URL=http://localhost:3000/

# Proxy Configuration
# Si tienes problemas con el proxy (404 errors), desactívalo:
# NEXT_PUBLIC_USE_PROXY=false
# Nota: Si desactivas el proxy, necesitarás configurar CORS en tu backend

# Si tu backend está en otro puerto, cámbialo aquí
# Ejemplo: NEXT_PUBLIC_API_URL=http://localhost:5000/api
